# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=""
# Get from @BotFather on Telegram: /newbot

# ─── LLM API — Google Gemini ─────────────────────────────────────────────────
GEMINI_API_KEY=
# Free key at: https://aistudio.google.com/app/apikey
LLM_PROVIDER=gemini

# ─── Google Sheets (Lead Capture) ────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON=credentials/google_service_account.json
GOOGLE_SHEET_ID=

# ─── Escalation Alerts — Slack ───────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ─── Escalation Alerts — Email (SMTP/Gmail) ──────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ESCALATION_EMAIL_TO=
ESCALATION_EMAIL_FROM=

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO
